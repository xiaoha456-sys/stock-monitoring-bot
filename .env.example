# QQ 邮箱 SMTP — 复制为 .env 并填入授权码（不是 QQ 登录密码）
# 获取授权码：QQ 邮箱 → 设置 → 账号 → POP3/IMAP/SMTP → 开启服务 → 生成授权码

SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=313265258@qq.com
SMTP_PASSWORD=你的QQ邮箱授权码
EMAIL_FROM=313265258@qq.com
EMAIL_TO=313265258@qq.com

# 可选：X/Twitter API Bearer Token（用于抓取金融大V推文情绪）
# 申请：https://developer.twitter.com/ → Projects → Bearer Token
# TWITTER_BEARER_TOKEN=your_bearer_token_here

# Web App（iOS / 本地）— 后端 API 地址，手机访问时填电脑局域网 IP
# VITE_API_BASE=http://192.168.1.10:8000
